    "version": "0.2.0",
    "configurations": [
    
        {
            "name": "novda (staging)",
            "request": "launch",
            "type": "dart",
            "args": [
                "--flavor", "staging",
                "--dart-define=STAGING=true"
            ]
        },
        {
            "name": "novda (staging release)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "args": [
                "--flavor", "staging",
                "--dart-define=STAGING=true"
            ]
        },
        {
            "name": "novda (production)",
            "request": "launch",
            "type": "dart",
            "args": [
                "--flavor", "production"
            ]
        },
        {
            "name": "novda (production release)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "args": [
                "--flavor", "production"
            ]
        },
        {
            "name": "novda_sdk",
            "cwd": "packages/novda_sdk",
            "request": "launch",
            "type": "dart"
        }
    ]
}